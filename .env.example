# Archaeon Environment Configuration
# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed to GitHub.

# Required: Your email address for NCBI Entrez API.
# NCBI uses this to contact you if your script causes issues.
# Without this, NCBI may block your requests.
NCBI_EMAIL=your_email@example.com

# Optional: NCBI API key for increased rate limits (10 req/s vs 3 req/s).
# Get free key at: https://www.ncbi.nlm.nih.gov/account/
# Leave blank to use the 3 req/s limit (fine for small runs).
NCBI_API_KEY=

# Optional: Output directory for reports and CSVs (default: data/outputs)
OUTPUT_DIR=data/outputs
